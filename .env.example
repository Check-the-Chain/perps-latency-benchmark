# Shared non-venue-specific local settings.
#
# Copy this to .env.local if you want a shared local file, then layer the
# venue-specific file for the exchange being tested:
#
#   go run ./cmd/perps-bench run \
#     --config examples/hyperliquid-builder.json \
#     --env-file .env.local \
#     --env-file .env.hyperliquid.local \
#     --confirm-live
#
# Later env files override earlier env files. Shell environment variables take
# precedence over all env files.

# Optional SDK/runtime settings can live here.
GRVT_ENV=prod
EXTENDED_ENV=mainnet
