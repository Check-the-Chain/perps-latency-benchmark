{
  "venue": "lighter",
  "benchmark": {
    "scenario": "single",
    "iterations": 10,
    "warmups": 2,
    "batch_size": 3,
    "rate_per_second": 0,
    "max_in_flight": 1,
    "stop_on_error": true,
    "latency_mode": "total",
    "measurement_mode": "ws_confirmation",
    "confirmation_timeout_ms": 10000
  },
  "http": {
    "timeout_ms": 10000,
    "max_idle_conns": 256,
    "max_idle_conns_per_host": 256,
    "disable_compression": true
  },
  "risk": {
    "allow_fill": true,
    "neutralize_on_fill": true
  },
  "cleanup": {
    "enabled": true,
    "mode": "strict",
    "scope": "after_sample",
    "timeout_ms": 15000
  },
  "request": {
    "transport": "https",
    "builder": {
      "type": "persistent_command",
      "command": [
        "uv",
        "run",
        "--with",
        "lighter-sdk",
        "python",
        "internal/venues/lighter/build_payload.py"
      ],
      "timeout_ms": 5000,
      "params": {
        "symbol": "BTC",
        "market_index": 1,
        "base_amount": 100,
        "price": 1500000,
        "side": "buy",
        "order_type": 1,
        "time_in_force": 0
      }
    }
  }
}
