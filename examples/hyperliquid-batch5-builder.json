{
  "venue": "hyperliquid",
  "benchmark": {
    "scenario": "batch",
    "iterations": 1,
    "warmups": 0,
    "batch_size": 5,
    "rate_per_second": 0.0033333333333333335,
    "max_in_flight": 1,
    "latency_mode": "total",
    "measurement_mode": "ws_confirmation",
    "confirmation_timeout_ms": 10000
  },
  "http": {
    "timeout_ms": 10000,
    "max_idle_conns": 16,
    "max_idle_conns_per_host": 8,
    "disable_compression": true
  },
  "risk": {
    "require_post_only": true
  },
  "cleanup": {
    "enabled": true,
    "mode": "best_effort",
    "scope": "after_sample",
    "timeout_ms": 15000
  },
  "rate_limit": {
    "enabled": true,
    "min_remaining": 100,
    "reserve_when_below": false,
    "reserve_target": 1000,
    "max_reserve_weight": 2000,
    "timeout_ms": 30000
  },
  "request": {
    "transport": "websocket",
    "builder": {
      "type": "persistent_command",
      "command": [
        "uv",
        "run",
        "--with",
        "hyperliquid-python-sdk",
        "--with",
        "eth-account",
        "python",
        "internal/venues/hyperliquid/build_payload.py"
      ],
      "timeout_ms": 5000,
      "params": {
        "symbol": "BTC",
        "asset": 0,
        "side": "buy",
        "size": "0.001",
        "price": "75000",
        "post_only_price_source": "hyperliquid_l2book_http",
        "post_only_price_offset_bps": 500,
        "post_only_price_refresh_ms": 300000,
        "price_step": "10",
        "tif": "Alo"
      }
    }
  }
}
