{
  "venue": "nado",
  "env_files": [
    ".env.nado.local"
  ],
  "benchmark": {
    "scenario": "batch",
    "iterations": 1,
    "warmups": 0,
    "batch_size": 5,
    "rate_per_second": 0.0033333333333333335,
    "max_in_flight": 1,
    "latency_mode": "total",
    "measurement_mode": "ws_confirmation",
    "confirmation_timeout_ms": 10000
  },
  "http": {
    "timeout_ms": 10000,
    "max_idle_conns": 16,
    "max_idle_conns_per_host": 8,
    "disable_compression": false
  },
  "risk": {
    "require_post_only": true
  },
  "cleanup": {
    "enabled": true,
    "mode": "best_effort",
    "scope": "after_sample",
    "timeout_ms": 15000
  },
  "request": {
    "transport": "https",
    "builder": {
      "type": "persistent_command",
      "command": [
        "uv",
        "run",
        "--python",
        "3.13",
        "--with",
        "eth-account",
        "python",
        "internal/venues/nado/build_payload.py"
      ],
      "timeout_ms": 5000,
      "params": {
        "product_id": 2,
        "symbol": "BTC-PERP",
        "side": "buy",
        "amount": "0.0014",
        "price": "77000",
        "order_type": "post_only",
        "recv_window_ms": 5000,
        "confirmation": true,
        "cancel_confirmation": true
      }
    }
  }
}
