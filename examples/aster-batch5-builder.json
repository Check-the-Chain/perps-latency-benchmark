{
  "venue": "aster",
  "benchmark": {
    "scenario": "batch",
    "iterations": 1,
    "warmups": 0,
    "batch_size": 5,
    "rate_per_second": 0.0033333333333333335,
    "max_in_flight": 1,
    "latency_mode": "total",
    "measurement_mode": "ws_confirmation",
    "confirmation_timeout_ms": 10000
  },
  "http": {
    "timeout_ms": 10000,
    "max_idle_conns": 256,
    "max_idle_conns_per_host": 256,
    "disable_compression": true
  },
  "risk": {
    "require_post_only": true
  },
  "cleanup": {
    "enabled": true,
    "mode": "best_effort",
    "scope": "after_sample",
    "timeout_ms": 15000
  },
  "request": {
    "transport": "https",
    "builder": {
      "type": "persistent_command",
      "command": [
        "uv",
        "run",
        "--python",
        "3.13",
        "--with",
        "eth-account",
        "python",
        "internal/venues/aster/build_payload.py"
      ],
      "timeout_ms": 15000,
      "params": {
        "symbol": "BTCUSDT",
        "side": "BUY",
        "type": "LIMIT",
        "time_in_force": "GTX",
        "quantity": "0.001",
        "price": "75000",
        "price_step": "10",
        "new_order_resp_type": "ACK",
        "cleanup_all_open_orders": true
      }
    }
  }
}
