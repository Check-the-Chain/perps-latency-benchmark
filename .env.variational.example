# Copy to .env.variational.local and fill locally. Do not commit local env files.

VARIATIONAL_API_KEY=
VARIATIONAL_API_SECRET=

# Optional. Set this if Variational gives you a private or environment-specific
# endpoint instead of the default SDK mainnet base URL.
VARIATIONAL_BASE_URL=

# Optional for RFQ submit tests. Comma-separated company IDs.
VARIATIONAL_TARGET_COMPANIES=
