# Copy to .env.pacifica.local and fill locally. Do not commit local env files.
#
# Prefer a bound API Agent Key for live benchmarks. When PACIFICA_ACCOUNT differs
# from the signing key's public key, the builder automatically sends the signing
# public key as agent_wallet.

PACIFICA_PRIVATE_KEY=
PACIFICA_ACCOUNT=
PACIFICA_AGENT_WALLET=
