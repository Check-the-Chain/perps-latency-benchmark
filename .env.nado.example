# Copy to .env.nado.local and fill locally. Do not commit local env files.

# EVM key for a Nado wallet or linked signer authorized for the subaccount.
NADO_PRIVATE_KEY=

# 32-byte subaccount sender: 20-byte wallet address + 12-byte ASCII subaccount name/padding.
# If omitted, the builder derives it from NADO_ADDRESS/NADO_SUBACCOUNT or the private key address + "default".
NADO_SENDER=
NADO_ADDRESS=
NADO_SUBACCOUNT=default

# Ink mainnet defaults to 57073. Ink Sepolia is 763373.
NADO_CHAIN_ID=57073

# Required for subscription authentication and cancellation signing.
# Retrieve via Nado's contracts query for the environment being tested.
NADO_ENDPOINT_CONTRACT=
