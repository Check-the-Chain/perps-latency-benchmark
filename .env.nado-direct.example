# Copy to .env.nado-direct.local and fill locally. Do not commit local env files.

# EVM key for the direct Nado runner. The local runner can reuse the
# LIGHTER_FREE_L1_PRIVATE_KEY wallet, but keep it copied here as NADO_PRIVATE_KEY.
NADO_PRIVATE_KEY=

# Optional guardrail address derived from NADO_PRIVATE_KEY.
NADO_ADDRESS=
NADO_SUBACCOUNT=default
NADO_CHAIN_ID=57073

# Required for subscription authentication and cancellation signing.
NADO_ENDPOINT_CONTRACT=
