# Copy to .env.grvt.local and fill locally. Do not commit local env files.

GRVT_PRIVATE_KEY=
GRVT_TRADING_ACCOUNT_ID=
GRVT_ENV=prod

# Auth/session material may be required by live GRVT submission depending on the
# endpoint/account setup. Keep any session cookies in the local file only.
GRVT_SESSION_COOKIE=
